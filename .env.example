# =============================================================================
# OUTBOUND AI CALLER — Environment Variables
# Copy this file to .env and fill in your values.
# =============================================================================


# ── LiveKit ──────────────────────────────────────────────────────────────────
# Get these from https://cloud.livekit.io/ → Project Settings → Keys
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=APIabc123...
LIVEKIT_API_SECRET=your_secret_here


# ── Google Gemini ─────────────────────────────────────────────────────────────
# Get your free API key from https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=AIza...

# Model for the Gemini Live realtime session
# Options: gemini-2.0-flash-live-001  |  gemini-2.5-flash  |  gemini-live-2.5-flash-native-audio
GEMINI_MODEL=gemini-2.0-flash-live-001

# Voice for Gemini Live audio output
# Options: Aoede | Puck | Charon | Kore | Fenrir | Orbit | Zephyr
GEMINI_TTS_VOICE=Aoede

# Set to false to force pipeline mode (Deepgram STT + Gemini LLM + Google TTS)
# Only do this if Gemini Live is unreliable in your region
USE_GEMINI_REALTIME=true


# ── VoiceLink SIP Trunk ───────────────────────────────────────────────────────
# From the VoiceLink reseller panel: https://app.voicelink.co.in/reseller/dids
# SIP Domain: found in Account → SIP Settings (e.g. sip.voicelink.co.in)
# Username / Password: shown per DID or SIP account in your reseller panel
VOICELINK_SIP_DOMAIN=your-domain.sip.voicelink.co.in
VOICELINK_USERNAME=your_sip_username
VOICELINK_PASSWORD=your_sip_password

# Your DID numbers in E.164 format (+91...). Add up to 4.
VOICELINK_OUTBOUND_NUMBER=+919XXXXXXXXX
VOICELINK_DID_2=
VOICELINK_DID_3=
VOICELINK_DID_4=

# LiveKit SIP trunk IDs — created automatically via /api/setup/trunk
# Run setup after configuring credentials above.
OUTBOUND_TRUNK_ID=ST_xxxxxxxxxxxxxxxxxxxx
INBOUND_TRUNK_ID=ST_xxxxxxxxxxxxxxxxxxxx
INBOUND_DISPATCH_RULE_ID=

# LiveKit SIP endpoint (your project's SIP URI from LiveKit Cloud Project Settings)
# Format: {project-id}.sip.livekit.cloud  (NO sip: prefix, NO trailing slash)
# VoiceLink panel: configure your DIDs to point to this as the SIP destination
LIVEKIT_SIP_ENDPOINT=your-project-id.sip.livekit.cloud

# Default number to transfer calls to when the lead asks for a human
DEFAULT_TRANSFER_NUMBER=+919999999999


# ── Telnyx SIP Trunk (alternative to VoiceLink/Vobiz) ─────────────────────────
# Create a SIP Connection (Credentials auth) in the Telnyx portal:
#   portal.telnyx.com -> Voice -> SIP Connections -> Create -> Credentials auth
# SIP Domain defaults to sip.telnyx.com (leave as-is unless told otherwise)
TELNYX_SIP_DOMAIN=sip.telnyx.com
TELNYX_USERNAME=your_telnyx_sip_connection_username
TELNYX_PASSWORD=your_telnyx_sip_connection_password
# Your Telnyx DID numbers in E.164 (+1...). Add up to 4.
TELNYX_OUTBOUND_NUMBER=+1XXXXXXXXXX
TELNYX_DID_2=
TELNYX_DID_3=
TELNYX_DID_4=
# Which provider is active: vobiz | telnyx. POST /api/setup/trunk/telnyx to switch.
ACTIVE_TELEPHONY_PROVIDER=vobiz


# ── Deepgram (pipeline fallback only) ────────────────────────────────────────
# Only required when USE_GEMINI_REALTIME=false
# Get a free key from https://console.deepgram.com/
DEEPGRAM_API_KEY=


# ── Twilio SMS (optional) ─────────────────────────────────────────────────────
# Leave all three blank to silently skip SMS confirmations
# Get from https://console.twilio.com/
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=


# ── API Server ────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000


# ── Database ──────────────────────────────────────────────────────────────────
# Path to the SQLite file (created automatically on first run)
DB_PATH=appointments.db
